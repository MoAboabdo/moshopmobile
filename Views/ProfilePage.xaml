<?xml version="1.0" encoding="utf-8" ?>
<!-- ProfilePage.xaml -->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ShopApp.Mobile.ViewModels"
             x:Class="ShopApp.Mobile.Views.ProfilePage"
             x:DataType="vm:ProfileViewModel"
             Title="Profile">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20">

            <!-- Avatar -->
            <Frame WidthRequest="100" HeightRequest="100" CornerRadius="50"
                   BackgroundColor="#6366F1" HorizontalOptions="Center" Padding="0">
                <Label Text="👤" FontSize="48" HorizontalOptions="Center" VerticalOptions="Center" />
            </Frame>

            <Label Text="{Binding Username}" FontSize="24" FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light=#1E293B, Dark=#F1F5F9}" />

            <!-- Info Cards -->
            <Frame BackgroundColor="{AppThemeBinding Light=White, Dark=#1E293B}" CornerRadius="12" Padding="16">
                <VerticalStackLayout Spacing="12">
                    <Grid ColumnDefinitions="Auto,*">
                        <Label Grid.Column="0" Text="Role" FontAttributes="Bold" FontSize="14"
                               TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" WidthRequest="100" />
                        <Frame Grid.Column="1" Padding="8,4" CornerRadius="6"
                               BackgroundColor="#EEF2FF" HorizontalOptions="Start">
                            <Label Text="{Binding Role}" TextColor="#6366F1" FontAttributes="Bold" FontSize="13" />
                        </Frame>
                    </Grid>
                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#E2E8F0, Dark=#334155}" />
                    <Grid ColumnDefinitions="Auto,*">
                        <Label Grid.Column="0" Text="Permissions" FontAttributes="Bold" FontSize="14"
                               TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" WidthRequest="100" />
                        <Label Grid.Column="1" Text="{Binding Permissions}" FontSize="13"
                               TextColor="{AppThemeBinding Light=#374151, Dark=#D1D5DB}"
                               LineBreakMode="WordWrap" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <Button Text="Logout" Command="{Binding LogoutCommand}"
                    BackgroundColor="#FEF2F2" TextColor="#DC2626"
                    CornerRadius="12" HeightRequest="52" FontAttributes="Bold"
                    BorderColor="#FCA5A5" BorderWidth="1" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
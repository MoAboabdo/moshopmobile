<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ShopApp.Mobile.ViewModels"
             xmlns:dto="clr-namespace:ShopApp.Mobile.DTOs"
             x:Class="ShopApp.Mobile.Views.UsersPage"
             x:DataType="vm:UsersViewModel"
             Title="Manage Users">

    <Grid RowDefinitions="*">

        <RefreshView Command="{Binding LoadUsersCommand}"
                     IsRefreshing="{Binding IsBusy}">
            <CollectionView ItemsSource="{Binding Users}" Margin="12">

                <CollectionView.EmptyView>
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="12">
                        <Label Text="👤" FontSize="48" HorizontalOptions="Center" />
                        <Label Text="No users found" FontSize="16" HorizontalOptions="Center"
                               TextColor="{AppThemeBinding Light=#94A3B8, Dark=#475569}" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="dto:UserDto">
                        <Frame Margin="0,0,0,12" CornerRadius="14" HasShadow="True"
                               BackgroundColor="{AppThemeBinding Light=White, Dark=#1E293B}">
                            <VerticalStackLayout Spacing="10">

                                <!-- User info -->
                                <Grid ColumnDefinitions="Auto,*">
                                    <Frame Grid.Column="0"
                                           WidthRequest="44" HeightRequest="44"
                                           CornerRadius="22" Padding="0"
                                           BackgroundColor="#6366F1"
                                           Margin="0,0,12,0">
                                        <Label Text="{Binding Username, Converter={StaticResource FirstLetterConverter}}"
                                               TextColor="White" FontAttributes="Bold"
                                               FontSize="18"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center" />
                                    </Frame>
                                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                        <Label Text="{Binding Username}"
                                               FontAttributes="Bold" FontSize="15"
                                               TextColor="{AppThemeBinding Light=#1E293B, Dark=#F1F5F9}" />
                                        <Label Text="{Binding Email}"
                                               FontSize="12"
                                               TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" />
                                        <Frame Padding="6,3" CornerRadius="6"
                                               BackgroundColor="#EEF2FF"
                                               HorizontalOptions="Start">
                                            <Label Text="{Binding Role}"
                                                   TextColor="#6366F1" FontSize="11"
                                                   FontAttributes="Bold" />
                                        </Frame>
                                    </VerticalStackLayout>
                                </Grid>

                                <!-- Action buttons -->
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                                    <Button Grid.Column="0"
                                            Text="Change Role"
                                            FontSize="12" HeightRequest="36"
                                            CornerRadius="8"
                                            BackgroundColor="#6366F1" TextColor="White"
                                            CommandParameter="{Binding .}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:UsersViewModel}}, Path=UpdateRoleCommand}" />

                                    <Button Grid.Column="1"
                                            Text="Permissions"
                                            FontSize="12" HeightRequest="36"
                                            CornerRadius="8"
                                            BackgroundColor="#9333EA" TextColor="White"
                                            CommandParameter="{Binding .}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:UsersViewModel}}, Path=ManagePermissionsCommand}" />
                                </Grid>

                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

        <!-- Error -->
        <Frame IsVisible="{Binding HasError}"
               BackgroundColor="#FEF2F2" BorderColor="#FCA5A5"
               CornerRadius="8" Padding="12" Margin="12"
               VerticalOptions="End">
            <Label Text="{Binding ErrorMessage}" TextColor="#DC2626" FontSize="14" />
        </Frame>

    </Grid>
</ContentPage>
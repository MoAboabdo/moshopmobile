<?xml version="1.0" encoding="utf-8" ?>
<!-- LoginPage.xaml -->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ShopApp.Mobile.ViewModels"
             x:Class="ShopApp.Mobile.Views.LoginPage"
             x:DataType="vm:LoginViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#0F172A}">

    <ScrollView>
        <VerticalStackLayout Padding="32,60,32,32" Spacing="20">

            <!-- Logo / Title -->
            <VerticalStackLayout Spacing="8" Margin="0,0,0,20">
                <Label Text="🛍️" FontSize="56" HorizontalOptions="Center" />
                <Label Text="Mohamed Shop" FontSize="32" FontAttributes="Bold"
                       TextColor="{AppThemeBinding Light=#1E293B, Dark=#F1F5F9}"
                       HorizontalOptions="Center" />
                <Label Text="Welcome back!" FontSize="16"
                       TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- Error Message -->
            <Frame IsVisible="{Binding HasError}" BackgroundColor="#FEF2F2"
                   BorderColor="#FCA5A5" CornerRadius="8" Padding="12">
                <Label Text="{Binding ErrorMessage}" TextColor="#DC2626" FontSize="14" />
            </Frame>

            <!-- Email -->
            <VerticalStackLayout Spacing="6">
                <Label Text="Email" FontAttributes="Bold" FontSize="14"
                       TextColor="{AppThemeBinding Light=#374151, Dark=#D1D5DB}" />
                <Frame BorderColor="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                       CornerRadius="10" Padding="4" BackgroundColor="{AppThemeBinding Light=White, Dark=#1E293B}">
                    <Entry Text="{Binding Email}" Placeholder="Enter your email"
                           Keyboard="Email" ReturnType="Next" />
                </Frame>
            </VerticalStackLayout>

            <!-- Password -->
            <VerticalStackLayout Spacing="6">
                <Label Text="Password" FontAttributes="Bold" FontSize="14"
                       TextColor="{AppThemeBinding Light=#374151, Dark=#D1D5DB}" />
                <Frame BorderColor="{AppThemeBinding Light=#E2E8F0, Dark=#334155}"
                       CornerRadius="10" Padding="4" BackgroundColor="{AppThemeBinding Light=White, Dark=#1E293B}">
                    <Entry Text="{Binding Password}" IsPassword="True" Placeholder="Enter your password" />
                </Frame>
            </VerticalStackLayout>

            <!-- Login Button -->
            <Button Text="Login" Command="{Binding LoginCommand}"
                    IsEnabled="{Binding IsNotBusy}"
                    BackgroundColor="#6366F1" TextColor="White"
                    CornerRadius="12" HeightRequest="52" FontSize="16" FontAttributes="Bold"
                    Margin="0,8,0,0" />

            <!-- Loading -->
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               Color="#6366F1" HorizontalOptions="Center" />

            <!-- Register Link -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                <Label Text="Don't have an account?" FontSize="14"
                       TextColor="{AppThemeBinding Light=#64748B, Dark=#94A3B8}" VerticalOptions="Center" />
                <Label Text="Register" FontSize="14" TextColor="#6366F1" FontAttributes="Bold">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoToRegisterCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
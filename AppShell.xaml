<?xml version="1.0" encoding="UTF-8" ?>
<Shell x:Class="ShopApp.Mobile.AppShell"
       xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:ShopApp.Mobile.Views"
       Shell.FlyoutBehavior="Flyout"
       Title="ShopApp">

    <ShellContent Route="loading"
              ContentTemplate="{DataTemplate views:LoadingPage}"
              Shell.FlyoutItemIsVisible="False" />

    <!-- Auth Routes (hidden from flyout) -->
    <ShellContent Route="login"    ContentTemplate="{DataTemplate views:LoginPage}"    Shell.FlyoutItemIsVisible="False" />
    <ShellContent Route="register" ContentTemplate="{DataTemplate views:RegisterPage}" Shell.FlyoutItemIsVisible="False" />

    <!-- Main Routes -->
    <FlyoutItem Title="Products"  Route="products">
        <FlyoutItem.Icon>
            <FontImageSource Glyph="🛍️" Size="22"/>
        </FlyoutItem.Icon>
        <ShellContent ContentTemplate="{DataTemplate views:ProductListPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Cart"  Route="cart">
        <FlyoutItem.Icon>
            <FontImageSource Glyph="🛒" Size="22"/>
        </FlyoutItem.Icon>
        <ShellContent ContentTemplate="{DataTemplate views:CartPage}" />
    </FlyoutItem>

    <FlyoutItem Title="My Orders"  Route="orders">
        <FlyoutItem.Icon>
            <FontImageSource Glyph="📦" Size="22"/>
        </FlyoutItem.Icon>
        <ShellContent ContentTemplate="{DataTemplate views:OrdersPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Profile"  Route="profile">
        <FlyoutItem.Icon>
            <FontImageSource Glyph="👤" Size="22"/>
        </FlyoutItem.Icon>
        <ShellContent ContentTemplate="{DataTemplate views:ProfilePage}" />
    </FlyoutItem>

    <!-- Admin only — hidden by default, shown after login if role == Admin -->
    <FlyoutItem Title="Admin Dashboard"  Route="admin"
                x:Name="AdminFlyoutItem" IsVisible="False">
        <FlyoutItem.Icon>
            <FontImageSource Glyph="⚙️" Size="22"/>
        </FlyoutItem.Icon>
        <ShellContent ContentTemplate="{DataTemplate views:AdminDashboardPage}" />
    </FlyoutItem>

</Shell>